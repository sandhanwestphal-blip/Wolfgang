---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer__inner">
    <p class="footer__name">Dr. Wolfgang Westphal</p>
    <p class="footer__beruf">Germanist & DaF/DaZ-Experte · Borken, Westfalen</p>

    <nav class="footer__nav">
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutz/">Datenschutz</a>
      <a href="mailto:redwest@web.de">redwest@web.de</a>
    </nav>

    <p class="footer__copy">© {year} Dr. Wolfgang Westphal</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--deep);
    color: rgba(245, 239, 230, 0.6);
    padding: 3rem 2rem;
    text-align: center;
  }
  .footer__inner {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }
  .footer__name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    color: var(--sand);
    letter-spacing: 0.05em;
  }
  .footer__beruf {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 0.5rem;
  }
  .footer__nav {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
    margin: 0.5rem 0;
  }
  .footer__nav a {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: rgba(245, 239, 230, 0.5);
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .footer__nav a:hover { color: var(--sand); }
  .footer__copy {
    font-size: 0.72rem;
    margin-top: 0.5rem;
    opacity: 0.4;
  }
</style>
