---
---
<section class="hero">
  <div class="hero__inner">
    <div class="hero__text">
      <p class="hero__label">KUNDE_BERUF · KUNDE_ORT</p>
      <h1 class="hero__title">
        KUNDE_NAME
      </h1>
      <div class="hero__quote">
        <blockquote>„Ihr persönliches Motto oder Leitsatz kommt hier hin."</blockquote>
        <cite>KUNDE_NAME</cite>
      </div>
      <a href="#kontakt" class="hero__cta">Erstgespräch vereinbaren</a>
    </div>
    <div class="hero__image">
      <!-- Ersetze durch: <img src="/KUNDE_FOTO.jpg" alt="KUNDE_NAME" /> -->
      <div class="hero__image-placeholder">
        <span>Foto<br />KUNDE_NAME</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    background: var(--sand);
    display: flex;
    align-items: center;
    padding: 7rem 2rem 4rem;
  }

  .hero__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  .hero__label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 1.2rem;
    animation: fadeUp 0.8s ease both;
  }

  .hero__title {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    color: var(--deep);
    margin-bottom: 2rem;
    animation: fadeUp 0.8s 0.1s ease both;
  }

  .hero__quote {
    border-left: 2px solid var(--terracotta);
    padding-left: 1.2rem;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.8s 0.2s ease both;
  }
  .hero__quote blockquote {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    font-style: italic;
    color: var(--text);
    line-height: 1.5;
  }
  .hero__quote cite {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terracotta);
    font-style: normal;
  }

  .hero__cta {
    display: inline-block;
    padding: 0.85rem 2rem;
    background: var(--terracotta);
    color: #fff;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: opacity 0.2s, transform 0.2s;
    animation: fadeUp 0.8s 0.3s ease both;
  }
  .hero__cta:hover { opacity: 0.85; transform: translateY(-2px); }

  .hero__image {
    animation: fadeIn 1s 0.4s ease both;
  }
  .hero__image img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
  }
  .hero__image-placeholder {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--warm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-light);
    font-size: 0.85rem;
    text-align: center;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero__image { order: -1; max-width: 320px; margin: 0 auto; width: 100%; }
  }
</style>
