---
---
<section class="hero">
  <div class="hero__inner">
    <div class="hero__text">
      <p class="hero__label">Germanist · DaF/DaZ-Experte · Borken, Westfalen</p>
      <h1 class="hero__title">
        Dr. Wolfgang Westphal
      </h1>
      <div class="hero__quote">
        <blockquote>„Sprache ist das Medium, in dem Menschen Zugang zur Gesellschaft, zur Arbeit und zu sich selbst finden."</blockquote>
        <cite>Dr. Wolfgang Westphal</cite>
      </div>
      <a href="#kontakt" class="hero__cta">Kontakt aufnehmen</a>
    </div>
    <div class="hero__image">
      <img
        src={`${import.meta.env.BASE_URL}Wolfgang.png`}
        alt="Dr. Wolfgang Westphal – Germanist und DaF/DaZ-Experte"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div class="hero__monogram" style="display:none">
        <span class="monogram__initials">W·W</span>
        <span class="monogram__title">Dr. phil.</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    background: var(--sand);
    display: flex;
    align-items: center;
    padding: 7rem 2rem 4rem;
  }

  .hero__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  .hero__label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 1.2rem;
    animation: fadeUp 0.8s ease both;
  }

  .hero__title {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    color: var(--deep);
    margin-bottom: 2rem;
    animation: fadeUp 0.8s 0.1s ease both;
  }

  .hero__quote {
    border-left: 2px solid var(--terracotta);
    padding-left: 1.2rem;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.8s 0.2s ease both;
  }
  .hero__quote blockquote {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    font-style: italic;
    color: var(--text);
    line-height: 1.5;
  }
  .hero__quote cite {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terracotta);
    font-style: normal;
  }

  .hero__cta {
    display: inline-block;
    padding: 0.85rem 2rem;
    background: var(--terracotta);
    color: #fff;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: opacity 0.2s, transform 0.2s;
    animation: fadeUp 0.8s 0.3s ease both;
  }
  .hero__cta:hover { opacity: 0.85; transform: translateY(-2px); }

  .hero__image {
    animation: fadeIn 1s 0.4s ease both;
  }
  .hero__image img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: top;
  }

  /* Fallback monogram shown when photo is missing */
  .hero__monogram {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--warm);
    border: 1px solid rgba(193,127,90,0.2);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
  }
  .monogram__initials {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 300;
    color: var(--terracotta);
    letter-spacing: 0.15em;
    line-height: 1;
  }
  .monogram__title {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-light);
  }

  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero__image { order: -1; max-width: 320px; margin: 0 auto; width: 100%; }
  }
</style>
